# Template for CatscanServer's local .env (auto-loaded by Vapor).
# Copy to .env and fill in real values:  cp .env.example .env

# Camera capture. Setting this enables the ffmpeg frame-capture lifecycle.
# Leave unset/commented to run the server without capture (e.g. for tests).
CAMERA_RTSP_URL=rtsp://CAMERA_HOST:8554/cam

# Full path to the ffmpeg executable. Required when the server is launched from
# Xcode (which inherits a minimal PATH that omits Homebrew). Run `which ffmpeg`.
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Where captured frames are written. Defaults to <workingDirectory>/events.
# EVENTS_DIR=./events

# Vapor log level: trace, debug, info, notice, warning, error, critical.
LOG_LEVEL=debug
